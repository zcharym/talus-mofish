<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="talus-mofish.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Talus\Talus Echo">
    </Installer>
    <PackageInformation
        PackageName="Talus Echo"
        PackageDisplayName="Talus Echo"
        PublisherName="CN=Talus"
        PublisherDisplayName="Talus"
        Version="0.1.0.0"
        PackageDescription="Chat-oriented desktop agent">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.talus.echoloop"
                Description="Chat-oriented desktop agent"
                DisplayName="Talus Echo"
                ExecutableName="talus-mofish.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Talus Echo</DisplayName>
            <PublisherDisplayName>Talus</PublisherDisplayName>
            <Description>Chat-oriented desktop agent</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="talus-mofish.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
